# Copy to .env and fill in values.
# NEVER commit .env to version control.

# ─── Supabase Configuration ───────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY is server-only. Never expose it in Expo/mobile builds.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# ─── AI Provider Keys (server-side only; never expose to frontend) ───────────
# Chat/NLP provider (Groq)
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Transcription provider (OpenAI Whisper-compatible)
OPENAI_TRANSCRIPTION_API_KEY=

# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=3001

# Allowed frontend origins (comma-separated)
# Add your LAN web origin too when testing from another device/browser.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081

# Node environment
NODE_ENV=development

# ─── Expo Push Notifications ──────────────────────────────────────────────────
# Optional Expo push token for the head manager/admin device used by the
# WhatsApp forward notification strategy.
ADMIN_EXPO_PUSH_TOKEN=

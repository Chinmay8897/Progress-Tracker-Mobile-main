# Copy this file to .env (same folder) and fill in the values.
# NOTE: .env is gitignored.

# Backend API URL (your Express server)
# iOS simulator / web on same machine:  http://localhost:3001
# Android emulator:                      http://10.0.2.2:3001
# Physical device (same Wi-Fi as laptop): http://<YOUR_LAN_IP>:3001
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Supabase client config (public anon key only; never put service-role keys in Expo)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
